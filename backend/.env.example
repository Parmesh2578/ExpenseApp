# Copy to .env and fill in values.
MONGODB_URI=mongodb://127.0.0.1:27017/expenseapp

# Auth — use a long random string (e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-min-16-chars-long-secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_DAYS=7

PORT=4000
# Comma-separated if Vite uses another port (e.g. 5174 when 5173 is busy)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
